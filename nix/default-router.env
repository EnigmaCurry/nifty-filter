# nifty-filter router configuration
# Edit this file and reboot to apply changes.
#
# This file lives on the writable /var partition.
# The rest of the system is immutable.
#
# Set ENABLED=true after configuring your interfaces.
ENABLED=false

# Network interfaces (run `ip link` to identify yours)
INTERFACE_LAN=enp1s0
INTERFACE_WAN=enp2s0

# LAN subnet in CIDR notation (router's LAN IP / prefix length)
SUBNET_LAN=192.168.10.1/24

# ICMP types accepted on each interface (comma-separated)
# Valid types: echo-request, echo-reply, destination-unreachable, time-exceeded
ICMP_ACCEPT_LAN=echo-request,echo-reply,destination-unreachable,time-exceeded
ICMP_ACCEPT_WAN=

# TCP/UDP ports the router itself accepts (comma-separated)
TCP_ACCEPT_LAN=22
UDP_ACCEPT_LAN=
TCP_ACCEPT_WAN=
UDP_ACCEPT_WAN=

# Port forwarding rules (comma-separated)
# Format: incoming_port:destination_ip:destination_port
# Example: 8080:192.168.10.50:80,2222:192.168.10.10:22
TCP_FORWARD_LAN=
UDP_FORWARD_LAN=
TCP_FORWARD_WAN=
UDP_FORWARD_WAN=
