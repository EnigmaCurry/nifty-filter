# nifty-filter configuration
# Edit this file and run: nifty-config -> Apply changes
#
# This file lives on the writable /var partition.
# The rest of the system is read-only (unless booted in maintenance mode).
#
# Set ENABLED=true after configuring your interfaces.
ENABLED=false
HOSTNAME=nifty-filter

# Network interfaces (renamed by the installer from real device names)
TRUNK_INTERFACE=trunk
WAN_INTERFACE=wan

# Management interface (optional — for out-of-band access, e.g. PVE vmbr0)
#MGMT_INTERFACE=mgmt
#MGMT_SUBNET=10.99.0.1/24

# WAN protocol enablement (at least one must be true)
WAN_ENABLE_IPV4=true
WAN_ENABLE_IPV6=false

# VLAN configuration
# VLAN_AWARE_SWITCH=false means VLAN 1 on the bare trunk (simple mode)
# VLAN_AWARE_SWITCH=true means only tagged VLANs, untagged trunk is blocked
VLAN_AWARE_SWITCH=false

# VLAN 1 — default LAN (untagged on trunk)
VLAN_1_SUBNET_IPV4=10.99.1.1/24
#VLAN_1_SUBNET_IPV6=fd00:10::1/64
VLAN_1_EGRESS_ALLOWED_IPV4=0.0.0.0/0
#VLAN_1_EGRESS_ALLOWED_IPV6=::/0
VLAN_1_ICMP_ACCEPT=echo-request,echo-reply,destination-unreachable,time-exceeded
#VLAN_1_ICMPV6_ACCEPT=nd-neighbor-solicit,nd-neighbor-advert,nd-router-solicit,nd-router-advert,echo-request,echo-reply
VLAN_1_TCP_ACCEPT=22
VLAN_1_UDP_ACCEPT=67,68
VLAN_1_TCP_FORWARD=
VLAN_1_UDP_FORWARD=

# WAN-side ICMP
WAN_ICMP_ACCEPT=
#WAN_ICMPV6_ACCEPT=nd-neighbor-solicit,nd-neighbor-advert,nd-router-solicit,nd-router-advert,destination-unreachable,packet-too-big,time-exceeded

# WAN-side ports
WAN_TCP_ACCEPT=22
WAN_UDP_ACCEPT=

# WAN port forwarding
# Format: incoming_port:destination_ip:destination_port
WAN_TCP_FORWARD=
WAN_UDP_FORWARD=

# Anti-spoofing: bogon/reserved source addresses dropped on WAN interface
#WAN_BOGONS_IPV4=0.0.0.0/8,10.0.0.0/8,100.64.0.0/10,127.0.0.0/8,169.254.0.0/16,172.16.0.0/12,192.0.0.0/24,192.0.2.0/24,192.168.0.0/16,198.18.0.0/15,198.51.100.0/24,203.0.113.0/24,224.0.0.0/4,240.0.0.0/4
#WAN_BOGONS_IPV6=::/128,::1/128,fc00::/7,ff00::/8

# DHCP for VLAN 1
VLAN_1_DHCP_ENABLED=true
VLAN_1_DHCP_POOL_START=10.99.1.100
VLAN_1_DHCP_POOL_END=10.99.1.250
VLAN_1_DHCP_ROUTER=10.99.1.1
# DNS server advertised to DHCP clients on this VLAN (usually the router itself)
VLAN_1_DHCP_DNS=10.99.1.1
# Static DHCP leases (mac,ip[,hostname] separated by semicolons)
#VLAN_1_DHCP_HOSTS=""

# DHCPv6 for VLAN 1 (enable and configure via nifty-config after install)
VLAN_1_DHCPV6_ENABLED=false
VLAN_1_DHCPV6_POOL_START=
VLAN_1_DHCPV6_POOL_END=

# Upstream DNS servers that dnsmasq forwards to (shared by all VLANs)
# Clients → dnsmasq (on router) → these upstream servers
DHCP_UPSTREAM_DNS="1.1.1.1, 1.0.0.1"

# --- QoS: Bufferbloat mitigation (CAKE) ---
# Set your raw speedtest results (both required to enable QoS).
# Effective rate is automatically reduced by WAN_QOS_SHAVE_PERCENT.
# Run: nifty-filter qos --env-file /var/nifty-filter/nifty-filter.env
#WAN_QOS_UPLOAD_MBPS=20
#WAN_QOS_DOWNLOAD_MBPS=300
#WAN_QOS_SHAVE_PERCENT=10
# Per-VLAN upload priority (voice, video, besteffort, bulk)
#VLAN_1_QOS_CLASS=besteffort
# Override priority for specific hosts/subnets
#QOS_OVERRIDE_VOICE=
#QOS_OVERRIDE_BULK=

# --- iperf3 bandwidth testing ---
# Firewall opens this port per-VLAN when VLAN_{ID}_IPERF_ENABLED=true
IPERF_PORT=5201
VLAN_1_IPERF_ENABLED=false

# --- nifty-dashboard web UI (requires nifty-dashboard package) ---
# TCP port for the dashboard (binds to MGMT_SUBNET address)
#NIFTY_DASHBOARD_PORT=3000

# --- Sodola switch management (requires sodola-switch package) ---
# Switch connection
#SODOLA_URL=http://192.168.2.1
#SODOLA_USER=admin
#SODOLA_PASS=admin
# Trunk interface and router IP for reaching the switch
#SODOLA_MGMT_IFACE=trunk
#SODOLA_ROUTER_IP=192.168.2.2/24

# VLAN list and names are inherited from VLANS and VLAN_{ID}_NAME above.
# VLAN 1 is automatically included for the switch. Override with SWITCH_VLANS if needed.
# Per-VLAN names fall back to VLAN_{ID}_NAME. Override with SWITCH_VLAN_{ID}_NAME if needed.

# Per-VLAN port modes (U=untagged, T=tagged, X=not-member, ports 1-9)
#SWITCH_VLAN_1_PORTS=X,X,X,X,X,X,X,U,U
#SWITCH_VLAN_10_PORTS=U,X,X,X,X,X,X,X,T
#SWITCH_VLAN_20_PORTS=X,U,X,X,X,X,X,X,T

# Per-port PVID (port:pvid)
#SWITCH_PVID=1:10,2:20,3:1,4:1,5:1,6:1,7:1,8:1,9:1

# Per-port accepted frame type (port:type — all, tag-only, untag-only)
#SWITCH_ACCEPT=1:untag-only,2:untag-only,3:all,4:all,5:all,6:all,7:all,8:all,9:all
