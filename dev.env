## Required environment vars:
INTERFACE_LAN=lan
INTERFACE_WAN=wan
SUBNET_LAN=192.168.10.1/24

## IPv6 (disabled by default):
# ENABLE_IPV4=true
# ENABLE_IPV6=false
# SUBNET_LAN_IPV6=fd00:10::1/64

## Default environment vars:
## ICMP responses are enabled for lan but disabled for wan:
# ICMP_ACCEPT_LAN=echo-request,echo-reply,destination-unreachable,time-exceeded
# ICMP_ACCEPT_WAN=
# ICMPV6_ACCEPT_LAN=nd-neighbor-solicit,nd-neighbor-advert,nd-router-solicit,nd-router-advert,echo-request,echo-reply
# ICMPV6_ACCEPT_WAN=nd-neighbor-solicit,nd-neighbor-advert,destination-unreachable,packet-too-big,time-exceeded
# TCP_ACCEPT_LAN=22,80,443
# TCP_ACCEPT_WAN=
# LAN_EGRESS_ALLOWED_IPV4=0.0.0.0/0
# LAN_EGRESS_ALLOWED_IPV6=::/0
# TCP_FORWARD_LAN=
# UDP_FORWARD_LAN=
# TCP_FORWARD_WAN=
# UDP_FORWARD_WAN=

## iperf3 bandwidth testing server:
# IPERF_PORT=5201
# VLAN_1_IPERF_ENABLED=false
