# Example: VLAN-aware router with managed switch
#
# Four VLANs with custom interface names:
## 10 "trusted" (SSH + internet)
## 20 "iot" (DHCP only)
## 30 "guest" (internet, no SSH)
## 40 "lab" (dual-stack)
##
# Load via: nifty-filter nftables --env-file vlan_router.env --strict-env

# Set the name of the physical trunk network device handling all VLAN traffic -
## systemd-networkd already provisioned 'trunk' interface by convention.
INTERFACE_TRUNK=trunk
# Set the name of the physical WAN network device -
## systemd-networkd already provisioned 'wan' interface by convention.
INTERFACE_WAN=wan

# When designing isolated VLANs, you MUST use a managed switch in addition to the router.
# Set up your switch so that the uplink to the router handles all tagged/untagged traffic.
# Set up the rest of the ports on the switch to handle specific tagged VLAN traffic only.
VLAN_AWARE_SWITCH=true
VLANS=10,20,30,40

# --- WAN: dual stack IPv4 / IPv6 ---
WAN_ENABLE_IPV4=true
WAN_ENABLE_IPV6=true

# --- VLAN 10: Trusted ---
# Full internet access + SSH to router
VLAN_10_NAME=trusted
VLAN_10_SUBNET_IPV4=10.99.10.1/24
VLAN_10_EGRESS_ALLOWED_IPV4=0.0.0.0/0
VLAN_10_ICMP_ACCEPT=echo-request,echo-reply,destination-unreachable,time-exceeded
VLAN_10_TCP_ACCEPT=22
VLAN_10_UDP_ACCEPT=67,68
VLAN_10_DHCP_ENABLED=true
VLAN_10_DHCP_POOL_START=10.99.10.100
VLAN_10_DHCP_POOL_END=10.99.10.250
VLAN_10_DHCP_ROUTER=10.99.10.1
VLAN_10_DHCP_DNS=10.99.10.1

# --- VLAN 20: IoT Jail ---
# DHCP only, no internet, no router access beyond DHCP
VLAN_20_NAME=iot
VLAN_20_SUBNET_IPV4=10.99.20.1/24
VLAN_20_EGRESS_ALLOWED_IPV4=
VLAN_20_ICMP_ACCEPT=destination-unreachable
VLAN_20_TCP_ACCEPT=
VLAN_20_UDP_ACCEPT=67,68
VLAN_20_DHCP_ENABLED=true
VLAN_20_DHCP_POOL_START=10.99.20.100
VLAN_20_DHCP_POOL_END=10.99.20.250
VLAN_20_DHCP_ROUTER=10.99.20.1
VLAN_20_DHCP_DNS=10.99.20.1

# --- VLAN 30: Guest ---
# Internet access but no SSH to router
VLAN_30_NAME=guest
VLAN_30_SUBNET_IPV4=10.99.30.1/24
VLAN_30_EGRESS_ALLOWED_IPV4=0.0.0.0/0
VLAN_30_ICMP_ACCEPT=echo-request,echo-reply,destination-unreachable,time-exceeded
VLAN_30_TCP_ACCEPT=
VLAN_30_UDP_ACCEPT=67,68
VLAN_30_DHCP_ENABLED=true
VLAN_30_DHCP_POOL_START=10.99.30.100
VLAN_30_DHCP_POOL_END=10.99.30.250
VLAN_30_DHCP_ROUTER=10.99.30.1
VLAN_30_DHCP_DNS=10.99.30.1

# --- VLAN 40: Lab (dual-stack) ---
# Full internet on both IPv4 and IPv6
#
# IPv6 addressing options:
#   - SLAAC (default): Clients auto-configure from the advertised prefix via
#     Router Advertisements. No DHCPv6 pool needed for addresses. This is the
#     common approach for public IPv6 — use your ISP's delegated prefix here.
#   - Stateful DHCPv6: Assign specific addresses from a pool. Useful for
#     stable/predictable addressing or ULA-only (private) networks.
#
# fd00::/7 is ULA (private, not routable on the public internet).
# For public IPv6, replace with a /64 from your ISP's delegated prefix.
VLAN_40_NAME=lab
VLAN_40_SUBNET_IPV4=10.99.40.1/24
VLAN_40_SUBNET_IPV6=fd00:40::1/64
VLAN_40_EGRESS_ALLOWED_IPV4=0.0.0.0/0
VLAN_40_EGRESS_ALLOWED_IPV6=::/0
VLAN_40_ICMP_ACCEPT=echo-request,echo-reply,destination-unreachable,time-exceeded
VLAN_40_TCP_ACCEPT=22
VLAN_40_UDP_ACCEPT=67,68,546,547
VLAN_40_DHCP_ENABLED=true
VLAN_40_DHCP_POOL_START=10.99.40.100
VLAN_40_DHCP_POOL_END=10.99.40.250
VLAN_40_DHCP_ROUTER=10.99.40.1
VLAN_40_DHCP_DNS=10.99.40.1
# DHCPv6 stateful pool (optional — SLAAC works without this)
VLAN_40_DHCPV6_ENABLED=true
VLAN_40_DHCPV6_POOL_START=fd00:40::100
VLAN_40_DHCPV6_POOL_END=fd00:40::1ff

# Allow inbound from WAN to specific hosts (no NAT - direct routing to public IPs)
# Use this when hosts have globally routable addresses (common with IPv6, rare with IPv4)
# Format: port:address (comma-separated, use brackets for IPv6)
# IPv6 example: 443:[2001:db8:abcd:40::50]
# IPv4 example: 443:203.0.113.50
VLAN_40_ALLOW_INBOUND_TCP=443:[2001:db8:abcd:40::50], 22:[2001:db8:abcd:40::10]
VLAN_40_ALLOW_INBOUND_UDP=

# WAN-side rules
ICMP_ACCEPT_WAN=
TCP_ACCEPT_WAN=
UDP_ACCEPT_WAN=

# WAN port forwarding (IPv4 NAT - incoming WAN port -> internal LAN IP:port)
# Format: incoming_port:destination_ip:destination_port (comma-separated)
TCP_FORWARD_WAN=443:10.99.40.50:443, 22:10.99.40.10:22
UDP_FORWARD_WAN=

# Upstream DNS
DHCP_UPSTREAM_DNS=1.1.1.1, 1.0.0.1
