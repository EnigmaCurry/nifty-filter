# Example: Dual-stack (IPv4 + IPv6) router configuration
# Load via: nifty-filter nftables --env-file dual_stack_router.env --strict-env

TRUNK_INTERFACE=trunk
WAN_INTERFACE=wan
VLAN_AWARE_SWITCH=false

# Enable both protocols on WAN
WAN_ENABLE_IPV4=true
WAN_ENABLE_IPV6=true

# VLAN 1 — the default LAN (untagged on trunk)
VLAN_1_SUBNET_IPV4=192.168.10.1/24
VLAN_1_SUBNET_IPV6=fd00:10::1/64
VLAN_1_EGRESS_ALLOWED_IPV4=0.0.0.0/0
VLAN_1_EGRESS_ALLOWED_IPV6=::/0

# Router access from LAN (defaults shown)
# VLAN_1_ICMP_ACCEPT=echo-request,echo-reply,destination-unreachable,time-exceeded
# VLAN_1_ICMPV6_ACCEPT=nd-neighbor-solicit,nd-neighbor-advert,nd-router-solicit,nd-router-advert,echo-request,echo-reply
VLAN_1_TCP_ACCEPT=22
VLAN_1_UDP_ACCEPT=67,68,546,547

# DHCP for VLAN 1
VLAN_1_DHCP_ENABLED=true
VLAN_1_DHCP_POOL_START=192.168.10.100
VLAN_1_DHCP_POOL_END=192.168.10.250
VLAN_1_DHCP_ROUTER=192.168.10.1
VLAN_1_DHCP_DNS=192.168.10.1

# DHCPv6 for VLAN 1
VLAN_1_DHCPV6_ENABLED=true
VLAN_1_DHCPV6_POOL_START=fd00:10::100
VLAN_1_DHCPV6_POOL_END=fd00:10::1ff

# --- QoS: Bufferbloat mitigation (CAKE) ---
# Set your raw speedtest results (both required to enable QoS).
# Effective rate is automatically reduced by WAN_QOS_SHAVE_PERCENT.
#WAN_QOS_UPLOAD_MBPS=20
#WAN_QOS_DOWNLOAD_MBPS=300
#WAN_QOS_SHAVE_PERCENT=10
#VLAN_1_QOS_CLASS=besteffort

# WAN-side ICMPv6 (defaults include ND, required for IPv6)
# WAN_ICMPV6_ACCEPT=nd-neighbor-solicit,nd-neighbor-advert,destination-unreachable,packet-too-big,time-exceeded

# WAN port forwarding (use brackets for IPv6: port:[ipv6_addr]:port)
WAN_TCP_FORWARD="8080:192.168.10.50:80, 8443:[fd00:10::50]:443"
WAN_UDP_FORWARD=

# Upstream DNS servers that dnsmasq forwards to (shared by all VLANs)
# Clients → dnsmasq (on router) → these upstream servers
# Per-VLAN DHCP_DNS sets what clients are told to use (usually the router itself)
DHCP_UPSTREAM_DNS="1.1.1.1, 1.0.0.1, 2606:4700:4700::1111, 2606:4700:4700::1001"
