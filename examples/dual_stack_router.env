# Example: Dual-stack (IPv4 + IPv6) router configuration
# Load via: nifty-filter nftables --env-file dual_stack_router.env --strict-env

INTERFACE_LAN=lan
INTERFACE_WAN=wan

# Enable both protocols
ENABLE_IPV4=true
ENABLE_IPV6=true

# LAN subnets
SUBNET_LAN_IPV4=192.168.10.1/24
SUBNET_LAN_IPV6=fd00:10::1/64

# IPv4 ICMP (defaults: echo-request, echo-reply, destination-unreachable, time-exceeded)
# ICMP_ACCEPT_LAN=echo-request,echo-reply,destination-unreachable,time-exceeded
# ICMP_ACCEPT_WAN=

# ICMPv6 (defaults include neighbor discovery, required for IPv6 to function)
# ICMPV6_ACCEPT_LAN=nd-neighbor-solicit,nd-neighbor-advert,nd-router-solicit,nd-router-advert,echo-request,echo-reply
# ICMPV6_ACCEPT_WAN=nd-neighbor-solicit,nd-neighbor-advert,destination-unreachable,packet-too-big,time-exceeded

# TCP/UDP ports the router itself accepts
TCP_ACCEPT_LAN=22
UDP_ACCEPT_LAN=67,68
TCP_ACCEPT_WAN=
UDP_ACCEPT_WAN=

# LAN egress filtering (default: allow all)
# Restrict LAN clients to specific destination ranges:
# LAN_EGRESS_ALLOWED_IPV4=0.0.0.0/0
# LAN_EGRESS_ALLOWED_IPV6=::/0

# Port forwarding (use brackets for IPv6: port:[ipv6_addr]:port)
TCP_FORWARD_LAN=
UDP_FORWARD_LAN=
TCP_FORWARD_WAN="8080:192.168.10.50:80, 8443:[fd00:10::50]:443"
UDP_FORWARD_WAN=
