# This is an example nifty-filter config for a simple home router.
# No managed switch required — VLAN 1 runs on the bare trunk interface.
# Load this via: nifty-filter nftables --env-file home_router.env --strict-env

# Network interfaces
TRUNK_INTERFACE=trunk
WAN_INTERFACE=wan
VLAN_AWARE_SWITCH=false

# VLAN 1 — the default LAN (untagged on trunk)
VLAN_1_SUBNET_IPV4=192.168.10.1/24
VLAN_1_EGRESS_ALLOWED_IPV4=0.0.0.0/0
VLAN_1_ICMP_ACCEPT=echo-request,echo-reply,destination-unreachable,time-exceeded
VLAN_1_TCP_ACCEPT=22,80,443
VLAN_1_UDP_ACCEPT=67,68
VLAN_1_TCP_FORWARD=
VLAN_1_UDP_FORWARD=

# DHCP for VLAN 1
VLAN_1_DHCP_ENABLED=true
VLAN_1_DHCP_POOL_START=192.168.10.100
VLAN_1_DHCP_POOL_END=192.168.10.250
VLAN_1_DHCP_ROUTER=192.168.10.1
VLAN_1_DHCP_DNS=192.168.10.1

# --- QoS: Bufferbloat mitigation (CAKE) ---
# Set your raw speedtest results (both required to enable QoS).
# Effective rate is automatically reduced by WAN_QOS_SHAVE_PERCENT.
#WAN_QOS_UPLOAD_MBPS=20
#WAN_QOS_DOWNLOAD_MBPS=300
#WAN_QOS_SHAVE_PERCENT=10
#VLAN_1_QOS_CLASS=besteffort

# WAN-side rules
WAN_ICMP_ACCEPT=
WAN_TCP_ACCEPT=
WAN_UDP_ACCEPT=

# WAN port forwarding (incoming WAN port -> internal LAN IP:port)
#WAN_TCP_FORWARD=8080:192.168.10.50:80, 2222:192.168.10.10:22
WAN_TCP_FORWARD=
WAN_UDP_FORWARD=

# Upstream DNS servers that dnsmasq forwards to (shared by all VLANs)
# Clients → dnsmasq (on router) → these upstream servers
# Per-VLAN DHCP_DNS sets what clients are told to use (usually the router itself)
DHCP_UPSTREAM_DNS="1.1.1.1, 1.0.0.1"
